{
  "name": "breadcraft",
  "version": "0.1.0",
  "description": "BreadCraft — Advanced Retro-Tech C64 game IDE",
  "main": "./out/main/index.js",
  "author": "Farbfinsternis",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "vue-tsc --noEmit -p tsconfig.web.json && electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "preview": "node scripts/run-electron-vite.mjs preview",
    "typecheck:node": "vue-tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "monaco-editor": "^0.52.2",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.5.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.1.10"
  }
}
